  "trigger_model": [
    {
      "key": "trigger_a",
      "label": "Establishment Failure",
      "default_role": "supporting_flag",
      "rule": "If NDVI rise from cycle start is less than 0.15 within 30-45 days, flag establishment risk.",
      "manual_review_conditions": [
        "low_confidence",
        "unknown_crop",
        "no_clear_cycle",
        "missing_ndvi"
      ]
    },
    {
      "key": "trigger_b",
      "label": "Mid-Season Vegetation Stress",
      "default_role": "primary_trigger",
      "formula": "((expected_ndvi - observed_ndvi) / expected_ndvi) * 100",
      "expected_ndvi_source_initial": "crop_or_cycle_median_from_available_plots",
      "expected_ndvi_source_future": "rolling_3_to_5_year_historical_baseline"
    },
    {
      "key": "trigger_c",
      "label": "Sudden Decline After Peak",
      "default_role": "supporting_flag",
      "rule": "If NDVI drops more than 0.25 within 15-30 days before expected harvest, flag stress for review.",
      "manual_review_conditions": [
        "calendar_mismatch",
        "possible_harvest",
        "low_confidence",
        "extreme_stress"
      ]
    }
  ],
  "payout_ladder": [
    {
      "stress_band": "no_stress",
      "condition": "ndvi_anomaly_pct < 10",
      "payout_pct": 0,
      "review_required": false
    },
    {
      "stress_band": "mild",
      "condition": "10 <= ndvi_anomaly_pct < 20",
      "payout_pct": 25,
      "review_required": false
    },
    {
      "stress_band": "moderate",
      "condition": "20 <= ndvi_anomaly_pct < 35",
      "payout_pct": 50,
      "review_required": false
    },
    {
      "stress_band": "severe",
      "condition": "ndvi_anomaly_pct >= 35",
      "payout_pct": 75,
      "review_required": "recommended_for_high_value_policies"
    },
    {
      "stress_band": "extreme",
      "condition": "ndvi_extremely_low_or_no_clear_crop_cycle",
      "payout_pct": 100,
      "review_required": true
    }
  ],
