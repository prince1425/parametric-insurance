{
  "phase": {
    "number": 2,
    "name": "System Architecture",
    "status": "complete",
    "next_phase": "Database Schema",
    "gate": "Do not implement database migrations, backend APIs, frontend screens, GIS modules, ML modules, tests, deployment, or production optimization until their phase is active."
  },
  "architecture_style": {
    "primary": "modular_monolith_with_async_workers",
    "evolution_path": "extract_services_only_when_scaling_or_ownership_requires_it",
    "rationale": [
      "keeps policy_trigger_approval_payout_consistency_simple",
      "preserves_domain_boundaries_for_later_service_extraction",
      "supports_demo_and_live_adapter_swap_without_business_logic_rewrite"
    ]
  },
